<section class="relative -mt-8 sm:-mt-10 lg:-mt-16 z-20 pb-12 sm:pb-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-3 gap-2 sm:gap-6">
      
      {% for stat in settings.stats %}
      <!-- Dynamic Stat Card -->
      <div class="bg-white border border-gray-100 rounded-2xl p-3 sm:p-6 flex flex-col sm:flex-row items-center sm:space-x-4 text-center sm:text-left shadow-md hover-lift justify-center sm:justify-start">
        <div class="w-10 h-10 sm:w-14 sm:h-14 {% if stat.color == 'pink' %}bg-pink/10 text-pink{% elif stat.color == 'yellow' %}bg-yellow/10 text-yellow-600{% else %}bg-primary/10 text-primary{% endif %} flex items-center justify-center rounded-xl sm:rounded-2xl shrink-0">
          {% if stat.icon == 'teachers' %}
            <svg class="w-5 h-5 sm:w-7 sm:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 00-2-2v3a2 2 0 002-2V9z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 11a2 2 0 100-4 2 2 0 000 4zm0 0v4m-3 0h6"></path>
            </svg>
          {% elif stat.icon == 'accreditation' %}
            <svg class="w-5 h-5 sm:w-7 sm:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
          {% else %}
            <svg class="w-5 h-5 sm:w-7 sm:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          {% endif %}
        </div>
        <div class="mt-2 sm:mt-0">
          <span class="block text-[10px] sm:text-2xl lg:text-3xl font-display font-extrabold text-navy leading-none sm:leading-tight">{{ stat.value }}</span>
          <span class="block text-[7px] sm:text-xs font-semibold text-gray-500 uppercase tracking-wider mt-0.5 sm:mt-1 leading-none">{{ stat.label }}</span>
        </div>
      </div>
      {% endfor %}

    </div>
  </div>
</section>
