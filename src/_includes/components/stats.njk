<section class="relative -mt-8 sm:-mt-10 lg:-mt-16 z-20 pb-12 sm:pb-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-3 gap-2 sm:gap-6">
      
      {% for stat in settings.stats %}
      <!-- Dynamic Stat Card (Minimalist text-only design) -->
      <div class="bg-white border border-gray-100 rounded-2xl p-4 sm:p-8 flex flex-col items-center text-center shadow-md hover-lift justify-center">
        <!-- Colored top accent bar -->
        <div class="w-8 h-1 rounded-full {% if stat.color == 'pink' %}bg-pink{% elif stat.color == 'yellow' %}bg-yellow{% else %}bg-primary{% endif %} mb-3 sm:mb-4"></div>
        
        <!-- Value and Label (Centered Stack) -->
        <span class="block text-2xl sm:text-4xl lg:text-5xl font-display font-extrabold text-navy leading-none">{{ stat.value }}</span>
        <span class="block text-[10px] sm:text-xs font-semibold text-gray-500 uppercase tracking-wider mt-2 sm:mt-3 leading-tight">{{ stat.label }}</span>
      </div>
      {% endfor %}

    </div>
  </div>
</section>
