<section class="relative bg-cream overflow-hidden pt-12 pb-20 lg:pt-16 lg:pb-28">
  <!-- Decorative background shapes -->
  <div class="absolute top-1/4 left-0 w-32 h-32 bg-yellow/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 right-0 w-72 h-72 bg-primary/5 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      
      <!-- Left Column: Content -->
      <div class="order-2 lg:order-1 lg:col-span-7 space-y-8 text-left">
        <!-- Badge announcement (only if PPDB is open) -->
        {% if settings.ppdbOpen %}
        <div class="inline-flex items-center space-x-2 bg-primary/10 text-primary px-4 py-2 rounded-full text-xs font-semibold hover-lift cursor-pointer">
          <span class="w-2.5 h-2.5 bg-primary rounded-full animate-ping"></span>
          <span>Pendaftaran PPDB TA {{ settings.ppdbYear }} Telah Dibuka!</span>
        </div>
        {% endif %}

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display text-navy tracking-tight leading-tight lg:leading-[1.1]">
          {{ settings.heroTitleFirst }} <br class="hidden sm:inline">
          <span class="text-primary">{{ settings.heroTitleSecond }}</span>
        </h1>

        <!-- Subheading Description -->
        <p class="text-gray-600 text-base sm:text-lg leading-relaxed max-w-2xl">
          {{ settings.description }}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4 items-center">
          <a href="/ppdb/" class="inline-flex items-center space-x-2 px-7 py-3.5 bg-primary hover:bg-primary-light text-white rounded-full font-semibold transition-all duration-300 shadow-lg shadow-primary/25 hover-lift">
            <span>Daftar PPDB</span>
            <span class="w-6 h-6 bg-white text-primary flex items-center justify-center rounded-full">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </span>
          </a>
          <a href="/tentang/" class="inline-flex items-center space-x-2 px-7 py-3.5 bg-white hover:bg-gray-50 text-navy border border-gray-200 rounded-full font-semibold transition-all duration-300 shadow-sm hover-lift">
            <span>Selengkapnya</span>
            <span class="w-6 h-6 bg-gray-100 text-gray-500 flex items-center justify-center rounded-full">
              <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </span>
          </a>
        </div>

        <!-- Highlights badges -->
        <div class="pt-6 border-t border-gray-100 flex flex-wrap gap-4">
          {% for highlight in settings.heroHighlights %}
          <div class="flex items-center space-x-2 bg-white px-4 py-2 rounded-full border border-gray-50 shadow-sm text-xs font-medium text-navy">
            <span class="w-2.5 h-2.5 rounded-full {% if loop.index0 % 4 == 0 %}bg-yellow{% elif loop.index0 % 4 == 1 %}bg-primary{% elif loop.index0 % 4 == 2 %}bg-pink{% else %}bg-blue{% endif %}"></span>
            <span>{{ highlight }}</span>
          </div>
          {% endfor %}
        </div>
      </div>

      <!-- Right Column: Visual Slideshow Gallery -->
      <div class="order-1 lg:order-2 lg:col-span-5 mt-10 lg:mt-0 flex justify-center lg:justify-end">
        <div x-data="{
               activeSlide: 0,
               slidesCount: {{ collections.gallery.length or 5 }},
               prev() {
                 this.activeSlide = this.activeSlide === 0 ? this.slidesCount - 1 : this.activeSlide - 1;
               },
               next() {
                 this.activeSlide = (this.activeSlide + 1) % this.slidesCount;
               }
             }" 
             class="relative w-full max-w-[380px] aspect-[4/5] bg-white border-4 border-white shadow-2xl rounded-3xl overflow-hidden group">
          
          <!-- Slides container -->
          <div class="w-full h-full relative">
            {% for item in collections.gallery | limit(5) %}
            <div x-show="activeSlide === {{ loop.index0 }}" 
                 x-transition:enter="transition ease-out duration-350"
                 x-transition:enter-start="opacity-0 scale-95"
                 x-transition:enter-end="opacity-100 scale-100"
                 class="absolute inset-0"
                 style="{% if not loop.first %}display: none;{% endif %}">
              
              <!-- Slide Image & Overlay -->
              <div class="w-full h-full bg-primary/5 flex flex-col items-center justify-center relative">
                <!-- Radial pattern fallback -->
                <div class="absolute inset-0 bg-primary/10 opacity-20 bg-[radial-gradient(#0D683E_1.5px,transparent_1.5px)] [background-size:16px_16px]"></div>
                
                <!-- Fallback Icon if image missing -->
                <svg class="w-16 h-16 text-primary/45 absolute" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                
                {% if item.data.image %}
                <img src="{{ item.data.image }}" alt="{{ item.data.title }}" class="w-full h-full object-cover relative z-10">
                {% endif %}

                <!-- Slide Info overlay at the bottom -->
                <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-navy/90 via-navy/55 to-transparent p-6 pt-16 text-white text-left z-20">
                  <span class="inline-block px-2.5 py-0.5 bg-primary text-[10px] font-bold rounded-full uppercase tracking-wider mb-2">
                    {{ item.data.category }}
                  </span>
                  <h4 class="text-lg font-bold font-display leading-tight">{{ item.data.title }}</h4>
                </div>
              </div>
              
            </div>
            {% endfor %}
          </div>

          <!-- Controls: Prev Button -->
          <button @click="prev()" 
                  class="absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/90 backdrop-blur-sm text-navy rounded-full shadow-md flex items-center justify-center hover:bg-white transition-all opacity-0 group-hover:opacity-100 focus:outline-none z-30">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
            </svg>
          </button>

          <!-- Controls: Next Button -->
          <button @click="next()" 
                  class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/90 backdrop-blur-sm text-navy rounded-full shadow-md flex items-center justify-center hover:bg-white transition-all opacity-0 group-hover:opacity-100 focus:outline-none z-30">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>

          <!-- Indicators -->
          <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex space-x-1.5 z-30">
            {% for item in collections.gallery | limit(5) %}
            <button @click="activeSlide = {{ loop.index0 }}" 
                    class="w-2.5 h-2.5 rounded-full transition-all"
                    :class="activeSlide === {{ loop.index0 }} ? 'bg-primary w-4' : 'bg-white/50'"></button>
            {% endfor %}
          </div>

          <!-- PPDB overlay badge -->
          <div class="absolute left-4 top-4 z-30 bg-white border border-[#E1F3EA] rounded-2xl px-3.5 py-2 shadow-lg">
            <span class="block text-[8px] font-bold text-primary uppercase tracking-wider leading-none">Pendaftaran</span>
            <span class="block text-xs font-black text-navy mt-1 leading-none">PPDB {{ settings.ppdbYear }}</span>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
