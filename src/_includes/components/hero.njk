<section class="relative bg-cream overflow-hidden pt-12 pb-20 lg:pt-16 lg:pb-28">
  <!-- Decorative background shapes -->
  <div class="absolute top-1/4 left-0 w-32 h-32 bg-yellow/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 right-0 w-72 h-72 bg-primary/5 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      
      <!-- Left Column: Content -->
      <div class="lg:col-span-7 space-y-8 text-left">
        <!-- Badge announcement (only if PPDB is open) -->
        {% if settings.ppdbOpen %}
        <div class="inline-flex items-center space-x-2 bg-primary/10 text-primary px-4 py-2 rounded-full text-xs font-semibold hover-lift cursor-pointer">
          <span class="w-2.5 h-2.5 bg-primary rounded-full animate-ping"></span>
          <span>Pendaftaran PPDB TA {{ settings.ppdbYear }} Telah Dibuka!</span>
        </div>
        {% endif %}

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display text-navy tracking-tight leading-tight lg:leading-[1.1]">
          Membentuk Generasi Qur'ani, <br>
          <span class="text-primary">Berakhlak & Berprestasi</span>
        </h1>

        <!-- Subheading Description -->
        <p class="text-gray-600 text-base sm:text-lg leading-relaxed max-w-2xl">
          {{ settings.description }}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4 items-center">
          <a href="/ppdb/" class="inline-flex items-center space-x-2 px-7 py-3.5 bg-primary hover:bg-primary-light text-white rounded-full font-semibold transition-all duration-300 shadow-lg shadow-primary/25 hover-lift">
            <span>Daftar PPDB</span>
            <span class="w-6 h-6 bg-white text-primary flex items-center justify-center rounded-full">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </span>
          </a>
          <a href="/tentang/" class="inline-flex items-center space-x-2 px-7 py-3.5 bg-white hover:bg-gray-50 text-navy border border-gray-200 rounded-full font-semibold transition-all duration-300 shadow-sm hover-lift">
            <span>Selengkapnya</span>
            <span class="w-6 h-6 bg-gray-100 text-gray-500 flex items-center justify-center rounded-full">
              <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </span>
          </a>
        </div>

        <!-- 4 Highlights badgess -->
        <div class="pt-6 border-t border-gray-100 flex flex-wrap gap-4">
          <div class="flex items-center space-x-2 bg-white px-4 py-2 rounded-full border border-gray-50 shadow-sm text-xs font-medium text-navy">
            <span class="w-2.5 h-2.5 bg-yellow rounded-full"></span>
            <span>Lingkungan Islami</span>
          </div>
          <div class="flex items-center space-x-2 bg-white px-4 py-2 rounded-full border border-gray-50 shadow-sm text-xs font-medium text-navy">
            <span class="w-2.5 h-2.5 bg-primary rounded-full"></span>
            <span>Pembelajaran Berkualitas</span>
          </div>
          <div class="flex items-center space-x-2 bg-white px-4 py-2 rounded-full border border-gray-50 shadow-sm text-xs font-medium text-navy">
            <span class="w-2.5 h-2.5 bg-pink rounded-full"></span>
            <span>Guru Profesional</span>
          </div>
          <div class="flex items-center space-x-2 bg-white px-4 py-2 rounded-full border border-gray-50 shadow-sm text-xs font-medium text-navy">
            <span class="w-2.5 h-2.5 bg-blue rounded-full"></span>
            <span>Fasilitas Nyaman</span>
          </div>
        </div>
      </div>

      <!-- Right Column: Visual Mockup matching the reference -->
      <div class="lg:col-span-5 relative flex justify-center lg:justify-end mt-10 lg:mt-0">
        <!-- Colored Circle Backgrounds behind the student image -->
        <div class="relative w-80 h-80 sm:w-96 sm:h-96">
          <div class="absolute inset-0 bg-pink rounded-full scale-[0.85] translate-x-4 -translate-y-4 opacity-10"></div>
          <div class="absolute inset-0 bg-primary rounded-full scale-[0.85] -translate-x-4 translate-y-4 opacity-5"></div>
          
          <!-- Cute background colorful blobs -->
          <div class="absolute -top-4 -right-4 w-20 h-20 bg-yellow rounded-full opacity-30 blur-xl"></div>
          <div class="absolute -bottom-8 -left-8 w-24 h-24 bg-blue rounded-full opacity-20 blur-xl"></div>

          <!-- Main Students Photo -->
          <img src="/assets/images/hero-students.png" alt="Siswa Al-Ishlah" class="relative z-10 w-full h-full object-contain drop-shadow-xl">
          
          <!-- Floating badge: PPDB Announcement -->
          <div class="absolute -right-4 top-1/3 z-20 bg-white border-2 border-[#E1F3EA] rounded-2xl p-4 shadow-xl max-w-[180px] hover-lift transition-all duration-300">
            <span class="block text-[10px] font-bold text-primary uppercase tracking-wider">Pendaftaran</span>
            <span class="block text-sm font-extrabold text-navy mt-1">PPDB {{ settings.ppdbYear }}</span>
            <span class="block text-[11px] font-bold text-red-500 mt-1 uppercase tracking-wide">TELAH DIBUKA!</span>
          </div>
          
          <!-- Small decorative stars/dots -->
          <div class="absolute top-6 left-6 w-4 h-4 bg-yellow rounded-full animate-bounce"></div>
          <div class="absolute bottom-16 right-4 w-3 h-3 bg-pink rounded-full"></div>
          <div class="absolute top-1/2 -left-6 w-5 h-5 bg-blue rounded-full animate-pulse"></div>
        </div>
      </div>

    </div>
  </div>
</section>
