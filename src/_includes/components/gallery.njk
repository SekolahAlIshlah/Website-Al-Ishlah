<section class="py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Heading -->
    <div class="flex items-end justify-between mb-12">
      <div class="text-left">
        <span class="block text-sm font-bold text-primary tracking-widest uppercase mb-2">Galeri Kegiatan</span>
        <h2 class="text-3xl sm:text-4xl font-display font-extrabold text-navy">
          Momen Kegiatan Kami
        </h2>
      </div>
      
      <!-- Link button -->
      <div>
        <a href="/galeri/" class="text-sm font-bold text-primary hover:text-primary-light transition-colors">
          Lihat Semua
        </a>
      </div>
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
      {% for item in collections.gallery | limit(6) %}
      <div class="aspect-square bg-white rounded-2xl shadow-md border border-gray-105 hover-lift relative group overflow-hidden">
        <div class="w-full h-full bg-primary/5 flex flex-col items-center justify-center relative">
          <!-- Radial pattern fallback -->
          <div class="absolute inset-0 bg-primary/10 opacity-20 bg-[radial-gradient(#0D683E_1px,transparent_1px)] [background-size:16px_16px]"></div>
          
          {% if item.data.image %}
          <img src="{{ item.data.image }}" alt="{{ item.data.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 relative z-10">
          {% else %}
          <!-- Icon fallback -->
          <svg class="w-10 h-10 text-primary/45 absolute" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="text-[10px] font-bold text-primary/80 uppercase mt-12 px-2 text-center absolute">{{ item.data.title }}</span>
          {% endif %}

          <!-- Hover Overlay -->
          <div class="absolute inset-0 bg-navy/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-20 flex flex-col justify-end p-4 text-left">
            <span class="text-[9px] font-bold text-primary-light uppercase tracking-wider">{{ item.data.category }}</span>
            <h4 class="text-xs font-bold text-white mt-1 leading-snug line-clamp-2">{{ item.data.title }}</h4>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

  </div>
</section>
