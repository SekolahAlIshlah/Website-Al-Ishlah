<section class="py-20 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Heading -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12">
      <div class="text-left">
        <span class="block text-sm font-bold text-primary tracking-widest uppercase mb-2">Guru Kami</span>
        <h2 class="text-3xl sm:text-4xl font-display font-extrabold text-navy">
          Guru & Ustadz Profesional
        </h2>
      </div>
      
      <!-- Carousel Nav Buttons -->
      <div class="flex space-x-3 mt-4 md:mt-0" x-data>
        <button @click="$dispatch('prev-teacher')" class="w-12 h-12 rounded-full border border-gray-200 text-navy hover:bg-primary hover:text-white flex items-center justify-center transition-colors duration-300 focus:outline-none">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        <button @click="$dispatch('next-teacher')" class="w-12 h-12 rounded-full border border-gray-200 text-navy hover:bg-primary hover:text-white flex items-center justify-center transition-colors duration-300 focus:outline-none">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Carousel Body -->
    <div x-data="{
           activeCard: 0,
           cardsCount: {{ collections.teachers.length or 5 }},
           scroll() {
             const slider = this.$refs.slider;
             if (!slider || !slider.firstElementChild) return;
             const cardWidth = slider.firstElementChild.getBoundingClientRect().width + 24; // width + gap
             slider.scrollTo({
               left: this.activeCard * cardWidth,
               behavior: 'smooth'
             });
           }
         }"
         @next-teacher.window="activeCard = (activeCard + 1) % cardsCount; scroll()"
         @prev-teacher.window="activeCard = activeCard === 0 ? cardsCount - 1 : activeCard - 1; scroll()"
         class="relative">
      
      <!-- Slider Track -->
      <div x-ref="slider" class="flex overflow-x-auto gap-6 scrollbar-hide pb-6 snap-x snap-mandatory px-8 sm:px-0" style="-ms-overflow-style: none; scrollbar-width: none;">
        
        {% for teacher in collections.teachers | sortOrder %}
        <!-- Teacher Card -->
        <div class="snap-center shrink-0 w-72 bg-cream/35 border border-gray-100 rounded-3xl p-6 text-center hover-lift relative overflow-hidden group">
          
          <!-- Alternating Color Themes -->
          {% set bgColors = ['bg-primary/10', 'bg-pink/10', 'bg-yellow/15', 'bg-blue/10'] %}
          {% set textColors = ['text-primary', 'text-pink', 'text-yellow-600', 'text-blue'] %}
          {% set borderColors = ['bg-primary', 'bg-pink', 'bg-yellow', 'bg-blue'] %}
          
          {% set colorIndex = loop.index0 % 4 %}
          {% set bgColor = bgColors[colorIndex] %}
          {% set textColor = textColors[colorIndex] %}
          {% set borderColor = borderColors[colorIndex] %}

          <!-- Blob background frame -->
          <div class="w-40 h-40 {{ bgColor }} rounded-full mx-auto mb-6 flex items-end justify-center overflow-hidden relative">
            <div class="absolute bottom-0 w-28 h-28 {{ borderColor }} rounded-t-full scale-90 opacity-20"></div>
            
            <!-- Custom Photo or Default Avatar SVG -->
            {% if teacher.data.photo and teacher.data.photo != '/assets/images/teachers/avatar-green.svg' %}
              <img src="{{ teacher.data.photo }}" alt="{{ teacher.data.title }}" class="w-full h-full object-cover relative z-10">
            {% else %}
              <svg class="w-24 h-24 {{ textColor }} relative z-10 translate-y-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
              </svg>
            {% endif %}
          </div>
          
          <h3 class="text-lg font-bold text-navy">{{ teacher.data.title }}</h3>
          <span class="block text-xs font-semibold {{ textColor }} mt-1">{{ teacher.data.role }}</span>
        </div>
        {% endfor %}

      </div>
    </div>

    <!-- Bottom link -->
    <div class="text-center mt-12">
      <a href="/guru/" class="inline-flex items-center space-x-2 text-primary font-bold text-sm hover:text-primary-light transition-colors group">
        <span>Lihat Semua Guru</span>
        <span class="w-8 h-8 bg-primary/10 text-primary flex items-center justify-center rounded-full transition-transform group-hover:translate-x-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </span>
      </a>
    </div>

  </div>
</section>
