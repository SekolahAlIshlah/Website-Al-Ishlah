   target="_blank" 
   rel="noopener" 
   class="fixed bottom-24 right-6 z-40 w-14 h-14 bg-[#25D366] hover:bg-[#20ba5a] text-white flex items-center justify-center rounded-full shadow-lg hover-lift transition-all duration-300 group"
   title="Hubungi Kami via WhatsApp"
   data-no-pjax>
  
