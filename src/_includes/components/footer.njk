        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-lg font-bold text-white mb-6">Menu</h3>
        <ul class="grid grid-cols-2 gap-3 text-sm">
          <li><a href="/" class="text-cream/80 hover:text-white transition-colors">Beranda</a></li>
          <li><a href="/tentang/" class="text-cream/80 hover:text-white transition-colors">Tentang Kami</a></li>
          <li><a href="/program/tkq/" class="text-cream/80 hover:text-white transition-colors">TKQ</a></li>
          <li><a href="/program/tpq/" class="text-cream/80 hover:text-white transition-colors">TPQ</a></li>
          <li><a href="/program/dta/" class="text-cream/80 hover:text-white transition-colors">DTA</a></li>
          <li><a href="/guru/" class="text-cream/80 hover:text-white transition-colors">Guru</a></li>
          <li><a href="/berita/" class="text-cream/80 hover:text-white transition-colors">Berita</a></li>
          <li><a href="/galeri/" class="text-cream/80 hover:text-white transition-colors">Galeri</a></li>
          <li><a href="/ppdb/" class="text-cream/80 hover:text-white transition-colors">PPDB</a></li>
          <li><a href="/faq/" class="text-cream/80 hover:text-white transition-colors">FAQ</a></li>
          <li><a href="/kontak/" class="text-cream/80 hover:text-white transition-colors">Kontak</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="space-y-4">
        <h3 class="text-lg font-bold text-white mb-6">Kontak Kami</h3>
        <ul class="space-y-4 text-sm text-cream/85">
          <li class="flex items-start space-x-3">
            <svg class="w-5 h-5 shrink-0 text-yellow mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>{{ settings.contact.address }}</span>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 shrink-0 text-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <span>{{ settings.contact.phone }}</span>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 shrink-0 text-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span>{{ settings.contact.email }}</span>
          </li>
        </ul>
      </div>

      <!-- Operational hours -->
      <div class="space-y-4">
        <h3 class="text-lg font-bold text-white mb-6">Jam Operasional</h3>
        <ul class="space-y-3 text-sm text-cream/85">
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 shrink-0 text-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>{{ settings.contact.operationalHoursWeekday }}</span>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 shrink-0 text-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>{{ settings.contact.operationalHoursWeekend }}</span>
          </li>
          <li class="flex items-center space-x-3 opacity-60">
            <svg class="w-5 h-5 shrink-0 text-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>Minggu: Tutup</span>
          </li>
        </ul>
      </div>

    </div>
    
    <div class="border-t border-white/10 pt-8 text-center text-xs text-cream/60">
      <p>&copy; {{ "" | dateDisplay }} {{ settings.schoolName }}. Hak Cipta Dilindungi Undang-Undang.</p>
    </div>
