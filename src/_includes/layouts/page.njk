---
layout: layouts/base.njk
---

<!-- Page Header Banner -->
<section class="bg-primary text-white py-16 relative overflow-hidden">
  <!-- Decorative background circle -->
  <div class="absolute right-0 top-0 w-80 h-80 bg-white/5 rounded-full translate-x-20 -translate-y-20"></div>
  <div class="absolute left-10 bottom-0 w-40 h-40 bg-white/5 rounded-full -translate-x-10 translate-y-10"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-display font-extrabold tracking-tight text-white !text-white">
      {{ title }}
    </h1>
    <!-- Breadcrumbs -->
    <nav class="flex justify-center mt-4 text-xs font-semibold text-cream/70 space-x-2 tracking-wide uppercase">
      <a href="/" class="text-cream hover:text-white transition-colors">Beranda</a>
      <span class="text-cream/50">/</span>
      <span class="text-white !text-white font-bold">{{ title }}</span>
    </nav>
  </div>
</section>

<!-- Page Content Container -->
<section class="py-16 bg-cream/15">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 bg-white border border-gray-100 rounded-3xl p-8 sm:p-12 shadow-sm">
    <article class="prose prose-navy max-w-none text-gray-600 leading-relaxed space-y-6">
      {% if image %}
      <div class="aspect-video w-full rounded-3xl overflow-hidden mb-8 relative bg-primary/5 flex items-center justify-center border border-gray-100 shadow-sm">
        <!-- Radial pattern fallback -->
        <div class="absolute inset-0 bg-primary/10 opacity-20 bg-[radial-gradient(#0D683E_1.5px,transparent_1.5px)] [background-size:18px_18px]"></div>
        
        <img src="{{ image }}" alt="{{ title }}" class="w-full h-full object-cover relative z-10" onerror="this.style.display='none'">
        
        <!-- Fallback SVG icon in the center -->
        <svg class="w-16 h-16 text-primary/30 absolute" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
      </div>
      {% endif %}
      
      {{ content | safe }}
    </article>
  </div>
</section>
