{
  "name": "web-al-ishlah",
  "version": "1.0.0",
  "description": "Website Resmi Sekolah Al-Ishlah",
  "main": "index.js",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/assets/css/input.css -o ./_site/assets/css/style.css --minify",
    "watch:css": "npx tailwindcss -i ./src/assets/css/input.css -o ./_site/assets/css/style.css --watch",
    "build:11ty": "npx eleventy",
    "watch:11ty": "npx eleventy --watch --serve --port=8080",
    "build": "npm run build:css && npm run build:11ty",
    "dev": "npx concurrently \"npm run watch:css\" \"npm run watch:11ty\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.4"
  }
}
